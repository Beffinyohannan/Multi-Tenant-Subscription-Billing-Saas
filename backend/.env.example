NODE_ENV=development
PORT=5000
HOST=localhost

# Neon connection string (preferred)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/subscription_billing?sslmode=require"

# Fallback individual fields (used only if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=subscription_billing
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

BCRYPT_SALT_ROUNDS=12
LOG_LEVEL=info

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
